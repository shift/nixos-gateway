# ALIX Custom Kernel Configuration
# Target: PC Engines ALIX (AMD Geode LX800, i686, 256MB RAM)
# All drivers built-in (=y), no module loader
# Minimal kernel for gateway/router use case

# === Platform ===
CONFIG_M486=y
CONFIG_MGEODE_LX=y
CONFIG_X86_GENERIC=y
CONFIG_X86_TSC=y
CONFIG_X86_CMOV=y
CONFIG_X86_CMPXCHG64=y
CONFIG_X86_GOOD_APIC=y
CONFIG_X86_INTEL_USERCOPY=y
CONFIG_X86_USE_PPRO_CHECKSUM=y
CONFIG_X86_MINIMUM_CPU_FAMILY=4
CONFIG_GENERIC_CPU=y
CONFIG_PROCESSOR_SELECT=y

# No PAE (Geode doesn't support it)
CONFIG_X86_PAE=n
CONFIG_HIGHMEM4G=y
CONFIG_HIGHMEM=y
CONFIG_HIGHPTE=y

# === Kernel basics ===
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_MULTIUSER=y
CONFIG_SYSFS=y
CONFIG_PROC_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_FUTEX=y
CONFIG_SHMEM=y

# Required by systemd/NixOS
CONFIG_BLK_DEV_INITRD=y
CONFIG_BINFMT_ELF=y
CONFIG_CGROUPS=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y
CONFIG_SECCOMP=y
CONFIG_AUTOFS_FS=y
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_LZORLE=y
CONFIG_CRYPTO_LZO=y
CONFIG_CRYPTO_LZO_RLE=y
CONFIG_CRYPTO_USER_API_HASH=y
CONFIG_DMIID=y

# No module loader
CONFIG_MODULES=n
CONFIG_MODULE_UNLOAD=n

# === PCI (needed for miniPCI WiFi cards) ===
CONFIG_PCI=y
CONFIG_PCI_GOANY=y
CONFIG_PCI_DOMAINS=y

# === Storage: CompactFlash via PATA (AMD CS5536) ===
CONFIG_IDE=n
CONFIG_ATA=y
CONFIG_ATA_PIIX=y
CONFIG_PATA_AMD=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV=y

# === Filesystems ===
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_XZ=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_HUGETLBFS=n
CONFIG_FUSE_FS=n
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y

# === Network: 2x Realtek RTL8139 onboard ===
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_NETDEVICES=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_8139CP=y
CONFIG_8139TOO=y
CONFIG_8139TOO_PIO=y
CONFIG_ETHERNET=y

# === WiFi: 2x CM9-GP (Atheros AR5212X) miniPCI ===
CONFIG_WIRELESS=y
CONFIG_WIRELESS_EXT=y
CONFIG_CFG80211=y
CONFIG_CFG80211_DEFAULT_PS=y
CONFIG_MAC80211=y
CONFIG_MAC80211_LEDS=y
CONFIG_ATH_COMMON=y
CONFIG_ATH5K=y
CONFIG_ATH5K_PCI=y

# === Serial console ===
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
CONFIG_CONSOLE_TRANSLATIONS=y

# === USB: 2x USB via CS5536 ===
CONFIG_USB=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_COMMON=y

# === Netfilter / nftables (firewall + NAT) ===
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_IPV4=y
CONFIG_NF_CONNTRACK_IPV6=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_IPV4=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_REJECT_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_QUEUE=y
CONFIG_NFT_FWD_NETDEV=y
CONFIG_NF_DEFRAG_IPV4=y
CONFIG_NF_DEFRAG_IPV6=y
CONFIG_NF_LOG_IPV4=y
CONFIG_NF_LOG_COMMON=y
CONFIG_NF_NAT_MASQUERADE_IPV4=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_MANGLE=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_TARGET_LOG=y
CONFIG_NETFILTER_XT_TARGET_TCPMSS=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_PKTTYPE=y
CONFIG_NETFILTER_XT_MATCH_LIMIT=y

# === WireGuard VPN ===
CONFIG_WIREGUARD=y
CONFIG_CRYPTO_CHACHA20=y
CONFIG_CRYPTO_POLY1305=y
CONFIG_CRYPTO_BLKCIPHER=y
CONFIG_CRYPTO_MANAGER=y

# === IPv6 ===
CONFIG_IPV6=y
CONFIG_IPV6_ROUTER_PREF=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_INET6_AH=n
CONFIG_INET6_ESP=n

# === Basic crypto (for WPA2, SSH, etc.) ===
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_586=y
CONFIG_CRYPTO_ARC4=y
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_CCM=y
CONFIG_CRYPTO_CMAC=y
CONFIG_CRYPTO_CRC32C=y
CONFIG_CRYPTO_DES=y
CONFIG_CRYPTO_DEV_GEODE=y
CONFIG_CRYPTO_ECB=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_GHASH=y
CONFIG_CRYPTO_HASH=y
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_HW=y
CONFIG_CRYPTO_MD5=y
CONFIG_CRYPTO_RNG=y
CONFIG_CRYPTO_SHA1=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_USER=n

# === ACPI / Power ===
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y

# === LED (ALIX has LEDs) ===
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_TRIGGERS=y

# === Watchdog (ALIX GPIO watchdog via CS5536) ===
CONFIG_WATCHDOG=y
CONFIG_GEODE_WDT=y

# === Miscellaneous ===
CONFIG_SYSCTL=y
CONFIG_KALLSYMS=n
CONFIG_MAGIC_SYSRQ=y

# === Disabled: not needed on ALIX ===
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_INPUT_JOYSTICK=n
CONFIG_INPUT_MOUSE=n
CONFIG_INPUT_KEYBOARD=n
CONFIG_HID=n
CONFIG_USB_HID=n
CONFIG_BLUETOOTH=n
CONFIG_IRDA=n
CONFIG_PHONE=n
CONFIG_RADIO=n
CONFIG_VIDEO_DEV=n
CONFIG_STAGING=n
CONFIG_IOMMU_SUPPORT=n
CONFIG_FTRACE=n
CONFIG_KPROBES=n
CONFIG_UPROBES=n
CONFIG_PROFILING=n
CONFIG_KEXEC=n
CONFIG_CRASH_DUMP=n
CONFIG_BSD_PROCESS_ACCT=n
CONFIG_TASKSTATS=n
CONFIG_NUMA=n
CONFIG_COMPACTION=n
CONFIG_TRANSPARENT_HUGEPAGE=n
